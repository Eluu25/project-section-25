# Backend environment template (deployment)
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-frontend-domain.com

# Security
JWT_SECRET=rf9b81814a3a7898c91bf936685476b3a9292ffaab7565454783dbbc199f08d14d22540d8adf064c9104bff1495f2a7226c1f56c38528cf002bc6946df985d4b1eplace_with_strong_64_char_secret
ENCRYPTION_KEY=replace_with_32_byte_encryption_key

# Database (PostgreSQL)
DB_CLIENT=postgres
DATABASE_URL=postgresql://db_user:db_password@db_host:5432/edekise_microfinance
DB_HOST=db_host
DB_PORT=5432
DB_NAME=edekise_microfinance
DB_USER=db_user
DB_PASSWORD=db_password
PG_SSL=true

# Email — Brevo Transactional API only (services/emailService.js + sib-api-v3-sdk)
# Create API key: Brevo → SMTP & API → API Keys
# Verify sender: Brevo → Senders
BREVO_API_KEY=(your_API_key_HERE)
BREVO_SENDER_EMAIL=endekise.microfinance@gmail.com
BREVO_SENDER_NAME=Edekise Microfinance

# File upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Loan policy controls
LOAN_SAVINGS_COLLATERAL_PERCENT=30
LOAN_SAVINGS_MIN_PERCENT=20
LOAN_LATE_PENALTY_RATE=1
LOAN_RATE_MICRO_ENTERPRISE=8
LOAN_RATE_INDIVIDUAL_BUSINESS=7.5
LOAN_RATE_CONSUMPTION=9
LOAN_RATE_CONSTRUCTION=12
LOAN_RATE_AGRICULTURAL_BUSINESS=10

# Seed users (disable in production)
SEED_DEFAULT_USERS=false
